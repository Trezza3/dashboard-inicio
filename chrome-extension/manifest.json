{
  "manifest_version": 3,
  "name": "Dashboard Inicio",
  "version": "0.3.0",
  "description": "Reemplaza la nueva pestana por el dashboard y muestra las pestanas y ventanas cerradas recientemente para reabrirlas.",
  "permissions": ["tabs", "sessions"],
  "host_permissions": [
    "https://dashboard-inicio.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard-inicio.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
