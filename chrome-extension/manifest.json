{
  "manifest_version": 3,
  "name": "Dashboard Inicio",
  "version": "1.0.0",
  "description": "Reemplaza la nueva pestana por el dashboard: pestanas cerradas recientemente e historial en el buscador.",
  "permissions": ["tabs", "sessions", "history"],
  "host_permissions": [
    "https://dashboard-inicio.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard-inicio.vercel.app/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
